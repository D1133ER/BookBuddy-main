# API Configuration
VITE_API_URL=http://localhost:3000/api
VITE_SOCKET_URL=http://localhost:3001
VITE_APP_NAME=BookBuddy

# Feature Flags
VITE_USE_MOCK_DB=true

# Optional: Google Books API Key (for enhanced metadata)
# VITE_GOOGLE_BOOKS_API_KEY=your_api_key_here

# Production Backend (when VITE_USE_MOCK_DB=false)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=admin
# DB_PASSWORD=password
# DB_NAME=bookbuddy

# Auth (for HTTP-only cookie auth)
# JWT_SECRET=your-secret-key-min-32-chars-long
# REFRESH_TOKEN_SECRET=another-secret-key-min-32-char

# Rate Limiting
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100